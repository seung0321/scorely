{
  "name": "@resumate/backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm --filter @resumate/types build && nodemon --watch src --exec ts-node src/server.ts",
    "build": "pnpm --filter @resumate/types build && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@google/genai": "^1.45.0",
    "@prisma/client": "^5.8.1",
    "@resumate/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.10.6",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
