{
  "name": "@resumate/backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "@fastify/multipart": "^8.1.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/cors": "^8.5.0",
    "@prisma/client": "^5.8.1",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@google/generative-ai": "^0.1.3",
    "bcrypt": "^5.1.1",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "@resumate/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "prisma": "^5.8.1",
    "@types/node": "^20.10.6",
    "@types/bcrypt": "^5.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  }
}
